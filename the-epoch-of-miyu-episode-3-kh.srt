បានគ្រប់គ្រងអាពាហ៍ពិពាហ៍របស់យើងបានល្អ

360
00:18:58,480 --> 00:19:00,310
ខ្ញុំអាចសម្រេចបានទាំងអស់។

361
00:19:01,330 --> 00:19:03,200
តែពេលនេះខ្ញុំឃើញហើយ

362
00:19:04,960 --> 00:19:06,200
មិនពិត

363
00:19:06,200 --> 00:19:08,070
ការស្វែងរករបស់ខ្ញុំគឺ។

364
00:19:10,840 --> 00:19:14,230
ពីថ្ងៃដែលខ្ញុំលះបង់ខ្លួនឯងដើម្បីអ្នក

365
00:19:15,670 --> 00:19:18,800
មិនមានរឿងបែបនេះទេ។
ជាអាពាហ៍ពិពាហ៍ដ៏ល្អឥតខ្ចោះទៀតហើយ។

366
00:19:20,480 --> 00:19:22,240
រវាងមនុស្សពីរនាក់ដែលលែង

367
00:19:22,240 --> 00:19:23,640
share ចង្វាក់ភ្លេងដូចគ្នា

368
00:19:24,510 --> 00:19:26,940
ទោះបីជា Lu Zhenzhen មិនមានវត្តមាននៅថ្ងៃនេះក៏ដោយ

369
00:19:27,310 --> 00:19:29,240
នឹងមាន Wang Zhenzhen,

370
00:19:29,240 --> 00:19:30,500
Li Zhenzhen នៅថ្ងៃស្អែក។

371
00:19:31,070 --> 00:19:33,600
អ្វី​ដែល​គួរ​ឱ្យ​ខ្លាច​នោះ​មិន​មែន​នោះ​ទេ។
អូនរើសមនុស្សខុស

372
00:19:34,350 --> 00:19:36,210
ប៉ុន្តែ​នោះ​តាំង​ពី​ដើម​មក

373
00:19:37,000 --> 00:19:39,070
ខ្ញុំភ្នាល់លើជីវិតខុស។

374
00:19:47,510 --> 00:19:48,750
សួស្តី តើនេះជាលោកស៊ូ?

375
00:19:51,200 --> 00:19:52,720
ខ្ញុំនឹងមកជួបអ្នកឥឡូវនេះ។

376
00:19:53,140 --> 00:19:54,630
[មេធាវី៖ ស៊ូ ស៊ាវនីង]

377
00:19:54,710 --> 00:19:56,080
[កិច្ចព្រមព្រៀងលែងលះ]

378
00:19:56,110 --> 00:19:56,580
[ក្រុមហ៊ុនមេធាវី ហេង ចេង]

379
00:19:56,580 --> 00:19:57,530
[មេធាវី៖ ស៊ូ ស៊ាវនីង]

380
00:20:00,510 --> 00:20:01,640
ផ្អែកលើព័ត៌មាន

381
00:20:01,640 --> 00:20:03,520
អំពីស្ថានភាពហិរញ្ញវត្ថុរបស់ស្វាមីអ្នក

382
00:20:03,060 --> 00:20:03,780
[យានជំនិះ] [ទ្រព្យសកម្មផ្សេងទៀត]

383
00:20:03,780 --> 00:20:08,320
[ជំនួយផ្នែកហិរញ្ញវត្ថុ និងសំណងសម្រាប់បញ្ហាផ្លូវចិត្ត]
[ពាក្យសុំវិញ្ញាបនបត្រលែងលះ]

384
00:20:03,960 --> 00:20:05,400
ខ្ញុំបានរៀបចំកិច្ចព្រមព្រៀង។

385
00:20:05,400 --> 00:20:06,270
សូមក្រឡេកមើល។

386
00:20:07,110 --> 00:20:09,910
ក្រៅពីទ្រព្យសម្បត្តិរួម
យើងដឹងហើយ

387
00:20:10,050 --> 00:20:12,840
ការសន្សំ និងការវិនិយោគ
គាត់បានលាក់ខ្លួនពីខ្ញុំ —

388
00:20:13,140 --> 00:20:14,210
ស្របច្បាប់

389
00:20:14,240 --> 00:20:15,400
ពួកគេក៏គួររាប់

390
00:20:15,400 --> 00:20:16,880
ជាកម្មសិទ្ធិអាពាហ៍ពិពាហ៍របស់យើងមែនទេ?

391
00:20:16,880 --> 00:20:17,550
ជាការពិតណាស់។

392
00:20:18,420 --> 00:20:19,110
ចំណូលណាមួយ

393
00:20:19,110 --> 00:20:21,030
រកបានក្នុងអំឡុងពេលរៀបការរបស់អ្នក

394
00:20:21,170 --> 00:20:22,550
នឹងបែងចែកស្មើៗគ្នា

395
00:20:22,550 --> 00:20:24,550
ប្រសិនបើអ្នកលែងលះ។

396
00:20:25,110 --> 00:20:26,310
និងសីលធម៌,

397
00:20:26,830 --> 00:20:29,030
វាមិនច្រើនពេកទេក្នុងការសុំនេះមែនទេ?

398
00:20:30,560 --> 00:20:31,240
ខ្ញុំដោះស្រាយជាមួយ

399
00:20:31,240 --> 00:20:33,020
គូស្វាមីភរិយាគ្រប់ប្រភេទជារៀងរាល់ថ្ងៃ។

400
00:20:33,790 --> 00:20:35,650
ទោះគេល្អប៉ុណ្ណាក៏ធ្លាប់

401
00:20:35,960 --> 00:20:37,890
នៅពេលដែលពួកគេសម្រេចចិត្តបោះជំហាននេះ

402
00:20:38,750 --> 00:20:39,680
វាជាសង្រ្គាម។

403
00:20:44,450 --> 00:20:48,290
[ស្នាមម្រាមដៃប្តី]
[ប្រពន្ធស្នាមម្រាមដៃ]

404
00:20:45,160 --> 00:20:46,070
នាង Xu,

405
00:20:46,720 --> 00:20:48,590
តើអ្នកប្រាកដអំពីការសម្រេចចិត្តនេះទេ?

406
00:20:57,080 --> 00:20:58,670
[ សណ្ឋាគារពោធិវង្ស ]

407
00:21:01,900 --> 00:21:03,410
[ សណ្ឋាគារពោធិវង្ស ]

408
00:21:04,050 --> 00:21:05,540
សូមស្វាគមន៍មកកាន់ សណ្ឋាគារ ពោធិ៍រ៉ុង។

409
00:21:12,790 --> 00:21:13,750
ខ្ញុំឃើញអ្នកបាន

410
00:21:13,750 --> 00:21:15,680
បានកក់បន្ទប់ស្តេចប្រណីត។

411
00:21:15,680 --> 00:21:17,750
- ខ្ញុំនឹង...
-Give me room 1819.

412
00:21:21,400 --> 00:21:22,540
ខ្ញុំ​សុំទោស​លោកស្រី។

413
00:21:22,670 --> 00:21:24,750
ភ្ញៀវក្នុងបន្ទប់ 1819 ទើបតែចេញ។

414
00:21:24,750 --> 00:21:26,880
- វានៅតែត្រូវបានសម្អាត។
- សោបន្ទប់។

415
00:21:27,110 --> 00:21:27,680
មិនអីទេ។

416
00:21:30,140 --> 00:21:32,450
អ្នកអាចរង់ចាំនៅហាងកាហ្វេ...

417
00:21:33,590 --> 00:21:34,280
នៅជិត។

418
00:21:36,070 --> 00:21:38,160
ហេតុអ្វីភ្ញៀវម្នាក់នេះ ពិបាកចិត្តម្ល៉េះ?

419
00:21:38,160 --> 00:21:40,560
មាននាយកដ្ឋាន HSKP
រក្សាភ្នែកលើនាង។

420
00:21:42,360 --> 00:21:45,400
ហេតុអ្វីបានជាខ្ញុំមានអារម្មណ៍បែបនេះ
ធ្លាប់​ឃើញ​នាង​នៅ​កន្លែង​ណា​មុន​?

421
00:22:55,510 --> 00:22:57,140
សួស្តី តើខ្ញុំអាចជួយអ្នកដោយរបៀបណា?

422
00:22:58,880 --> 00:22:59,590
សូមស្វាគមន៍។

423
00:22:59,590 --> 00:23:01,120
ត្រូវប្រាកដថាអ្នកសម្រាកខ្លះ។

424
00:23:29,060 --> 00:23:34,350
[ទឹកឃ្មុំ]

425
00:23:32,600 --> 00:23:33,350
ស្នេហ៍អើយ

426
00:23:33,590 --> 00:23:34,520
អ្នកមិននៅផ្ទះ?

427
00:23:36,440 --> 00:23:37,790
មានកម្មវិធីជប់លៀងអបអរសាទរគម្រោង
យប់នេះ។

428
00:23:37,790 --> 00:23:38,590
អ្នកត្រូវតែមក។

429
00:23:40,270 --> 00:23:41,680
ដៃគូរបស់យើងទាំងអស់នឹងនៅទីនោះ

430
00:23:41,680 --> 00:23:44,210
ហើយគ្រប់គ្នានិយាយ
ពួកគេពិតជាចង់ជួបអ្នក។

431
00:23:44,750 --> 00:23:45,880
ខ្ញុំបានផ្ញើទីតាំងទៅអ្នក។

432
00:23:45,880 --> 00:23:47,210
ចំណាយពេលរបស់អ្នក។ គ្មានការប្រញាប់។

433
00:23:47,550 --> 00:23:49,460
[ទឹកឃ្មុំ]

434
00:23:48,360 --> 00:23:49,390
ស្រឡាញ់អ្នក សូមមើល។

435
00:23:51,130 --> 00:23:52,980
[ទឹកឃ្មុំ]

436
00:23:51,880 --> 00:23:52,810
ស្រឡាញ់អ្នក, ទឹកឃ្មុំ។

437
00:24:07,640 --> 00:24:09,630
បំបែក។ ឃ្លាមួយ។ ពាក្យពីរ។

438
00:24:10,630 --> 00:24:12,980
វាចំណាយពេលត្រឹមតែមួយវិនាទីដើម្បីនិយាយ។

439
00:24:13,340 --> 00:24:14,740
ប៉ុន្តែអ្នកមិនបាន។

440
00:24:15,830 --> 00:24:17,310
គំនិតអ្នកនិង Lu Zhenzhen

441
00:24:17,310 --> 00:24:19,680
ស្ទាបអង្អែល

442
00:24:19,700 --> 00:24:21,700
ព្រឺសម្បុរដូចសត្វ

443
00:24:22,160 --> 00:24:24,200
ត្រង់នេះលើគ្រែនេះ

444
00:24:25,830 --> 00:24:27,340
ធ្វើឱ្យខ្ញុំតាំងចិត្ត។

445
00:25:06,090 --> 00:25:08,340
[មន្ទីរពេទ្យសម្ភពមីងម៉ី
សេចក្តីថ្លែងការណ៍វិក័យប័ត្រ]

446
00:25:20,050 --> 00:25:20,460
[ជំរាបសួរលោកស្រី Lu Zhenzhen ។]

447
00:25:20,490 --> 00:25:21,310
[យើងខ្ញុំសូមគោរពអញ្ជើញលោកអ្នកចូលរួម]

448
00:25:21,330 --> 00:25:22,130
[ពិធីជប់លៀង
សម្រាប់គម្រោង Yufeng Jiangnan ។]

449
00:25:30,260 --> 00:25:31,610
[ប្រធានបទ៖ ការអញ្ជើញទៅគម្រោង Yufeng Jiangnan
ពិធីជប់លៀង]

450
00:25:31,870 --> 00:25:32,860
[ផ្ញើ]

451
00:25:39,310 --> 00:25:40,680
គម្រោង Yufeng Jiangnan,

452
00:25:40,680 --> 00:25:42,030
ថាតើសម្រាប់ Changyang

453
00:25:42,030 --> 00:25:43,310
ឬសម្រាប់ខ្ញុំផ្ទាល់

454
00:25:43,310 --> 00:25:45,030
គឺជាអាទិភាពកំពូលនៅឆ្នាំនេះ។

455
00:25:45,030 --> 00:25:46,200
នេះគឺជាគម្រោងសំខាន់មួយ។

456
00:25:46,200 --> 00:25:48,550
ការពិតនោះ។
វាដំណើរការយ៉ាងរលូនដល់ចំណុចនេះ

457
00:25:48,550 --> 00:25:50,680
សូមអរគុណដល់អ្នកទាំងអស់គ្នានៅទីនេះ។

458
00:25:50,680 --> 00:25:51,510
អរគុណអ្នកទាំងអស់គ្នា

459
00:25:51,830 --> 00:25:52,680
សម្រាប់ការគាំទ្ររបស់អ្នក

460
00:25:52,680 --> 00:25:53,720
ការលើកទឹកចិត្ត និងកិច្ចសហប្រតិបត្តិការ។

461
00:25:53,720 --> 00:25:54,510
ដល់កិច្ចសហប្រតិបត្តិការរបស់យើង។

462
00:25:54,510 --> 00:25:55,270
មក។

463
00:25:55,300 --> 00:25:56,440
- ចំពោះកិច្ចសហប្រតិបត្តិការរបស់យើង។
- ចំពោះកិច្ចសហប្រតិបត្តិការរបស់យើង។

464
00:25:56,440 --> 00:25:57,680
អរគុណអ្នកទាំងអស់គ្នា។

465
00:25:57,680 --> 00:25:58,310
សូមអរគុណ។

466
00:25:58,310 --> 00:25:59,000
សូមអរគុណលោកលី។

467
00:25:59,000 --> 00:25:59,510
នេះជាកិច្ចសហប្រតិបត្តិការរបស់យើង។

468
00:25:59,510 --> 00:26:01,910
- ចំពោះកិច្ចសហប្រតិបត្តិការរបស់យើង។
- ចំពោះកិច្ចសហប្រតិបត្តិការរបស់យើង។

469
00:26:04,030 --> 00:26:04,830
សូមអរគុណ។

470
00:26:04,850 --> 00:26:05,860
សូមអង្គុយចុះ។

471
00:26:05,860 --> 00:26:06,420
លោក នី។

472
00:26:06,810 --> 00:26:08,030
តើ​នាង​នី​នឹង​មក​ចូលរួម​ជាមួយ​យើង​នៅ​ថ្ងៃ​នេះ​ទេ?

473
00:26:08,030 --> 00:26:09,090
បាទ នាងកំពុងមក។

474
00:26:09,310 --> 00:26:10,240
នាងគួរតែនៅទីនេះឆាប់ៗនេះ។

475
00:26:10,240 --> 00:26:10,870
អនុញ្ញាតឱ្យខ្ញុំសួរនាង។

476
00:26:10,460 --> 00:26:12,220
[ទឹកឃ្មុំ]

477
00:26:11,720 --> 00:26:12,520
ខ្ញុំសូមប្រាប់អ្នក។

478
00:26:12,260 --> 00:26:15,430
[តើអ្នកនៅឯណា?]

479
00:26:12,830 --> 00:26:14,330
ខ្ញុំបានលឺយូរមកហើយ
ថាប្រពន្ធលោកនី

480
00:26:14,330 --> 00:26:16,810
- តើអ្នកនៅឯណា?
- ត្រូវបានគេនិយាយថានាំសំណាងដល់គាត់។

481
00:26:16,810 --> 00:26:19,170
បើយើងឃើញនាងនីនៅទីនេះថ្ងៃនេះ

482
00:26:19,310 --> 00:26:20,720
វានឹងក្លាយជាកិត្តិយសរបស់យើង។

483
00:26:20,720 --> 00:26:21,440
ពិត។

484
00:26:21,480 --> 00:26:22,510
អ្នកចិត្តល្អពេកហើយ។

485
00:26:22,510 --> 00:26:23,310
ខ្ញុំមិនដែលឃើញនាងពីមុនមកទេ។

486
00:26:23,310 --> 00:26:24,000
អស្ចារ្យ។

487
00:26:26,640 --> 00:26:27,280
អ្នកស្រី នី។

488
00:26:28,340 --> 00:26:29,720
នាងឆើតឆាយណាស់។

489
00:26:30,050 --> 00:26:31,180
នាងស្អាតណាស់។

490
00:26:31,800 --> 00:26:32,490
ទឹកឃ្មុំ។

491
00:26:33,500 --> 00:26:35,030
ខ្ញុំសូមណែនាំអ្នកទាំងអស់គ្នា។

492
00:26:35,110 --> 00:26:36,680
នេះ​គឺ​ជា​ប្រពន្ធ​របស់​ខ្ញុំ Xu Miyu ។

493
00:26:37,030 --> 00:26:37,920
សុំទោស

494
00:26:37,920 --> 00:26:38,800
សម្រាប់ការយឺត។

495
00:26:39,350 --> 00:26:40,880
លោក នី ពិត​ជា​មនុស្ស​សំណាង​មែន។

496
00:26:40,890 --> 00:26:41,920
- សូមអរគុណ។ សូមអរគុណ។
- បាទ។ បាទ។

497
00:26:41,920 --> 00:26:42,740
អ្នក​ជា​មនុស្ស​សំណាង​ណាស់​លោក​នី។

498
00:26:42,740 --> 00:26:44,690
តោះ​សុំ​ធ្វើ​នំ​ជា​គូ។

499
00:26:44,960 --> 00:26:45,550
មិនអីទេ។

500
00:26:45,550 --> 00:26:46,050
នៅទីនេះ។

501
00:26:46,480 --> 00:26:47,550
សម្រាប់កិច្ចសហប្រតិបត្តិការរបស់យើងទាំងអស់គ្នា។

502
00:26:47,550 --> 00:26:48,590
- ចំពោះកិច្ចសហប្រតិបត្តិការរបស់យើង។
- ចំពោះកិច្ចសហប្រតិបត្តិការរបស់យើង។

503
00:26:48,590 --> 00:26:49,270
រីករាយ។

504
00:26:49,290 --> 00:26:50,070
ដល់កិច្ចសហប្រតិបត្តិការរបស់យើង។

505
00:26:50,070 --> 00:26:51,670
អ្នកគឺជាការប្រកួតដ៏ល្អឥតខ្ចោះ។

506
00:26:55,850 --> 00:26:56,710
មកអង្គុយចុះ។

507
00:26:58,710 --> 00:26:59,360
នៅទីនេះ។

508
00:27:02,310 --> 00:27:04,110
ជាធម្មតាអ្នកមិនញ៉ាំក្តាម

509
00:27:04,110 --> 00:27:05,300
ដោយសារតែខ្ញុំ។

510
00:27:05,830 --> 00:27:08,130
សាកល្បង​ក្តាម​នៅ​ទីនេះ​មើល​ថា​តើ​វា​មាន​រសជាតិ​យ៉ាងណា។

511
00:27:11,110 --> 00:27:12,370
អ្នកណាបញ្ជាក្តាមនេះ?

512
00:27:13,550 --> 00:27:15,410
នេះត្រូវបានគេចាត់ទុកថាជាអាហារ "ត្រជាក់" ។

513
00:27:15,920 --> 00:27:18,250
មិន​បារម្ភ​ខ្លាច​ខូច​កូន​ទេ?

514
00:27:18,250 --> 00:27:19,070
លោកនី!

515
00:27:19,240 --> 00:27:20,880
អ្នកមានសុភមង្គលទ្វេដង!

516
00:27:20,880 --> 00:27:21,880
សូមអបអរសាទរលោកថៅកែ។

517
00:27:21,880 --> 00:27:23,110
តើរឿងនេះកើតឡើងនៅពេលណា Boss?

518
00:27:23,110 --> 00:27:24,540
ហេតុអ្វីបានជាអ្នកមិនប្រាប់យើង?

519
00:27:24,600 --> 00:27:25,260
នាងនី...

520
00:27:25,680 --> 00:27:27,050
កុំធ្វើរឿងអាស្រូវបែបនេះ។

521
00:27:27,110 --> 00:27:27,600
ញ៉ាំ។

522
00:27:27,620 --> 00:27:29,020
- ញ៉ាំ។
- វាជាដំណឹងល្អ។

523
00:27:29,120 --> 00:27:30,230
តោះញ៉ាំ។

524
00:27:30,770 --> 00:27:33,310
Minghui គ្រួសាររបស់អ្នកសុខសប្បាយជាទេ?

525
00:27:33,360 --> 00:27:34,760
តើ 150,000 គ្រប់គ្រាន់ទេ?

526
00:27:35,770 --> 00:27:36,330
បាទ។

527
00:27:36,760 --> 00:27:37,620
វាគ្រប់គ្រាន់ហើយ។

528
00:27:37,980 --> 00:27:39,260
ប្រាប់ខ្ញុំប្រសិនបើវាមិនគ្រប់គ្រាន់។

529
00:27:39,260 --> 00:27:41,060
ខ្ញុំបានពិនិត្យតម្លៃរបស់មីងម៉ី។

530
00:27:41,150 --> 00:27:43,000
ប្រសិនបើវាជាកំណើតធម្មជាតិ
មជ្ឈមណ្ឌលថែទាំក្រោយសម្រាល,

531
00:27:43,000 --> 00:27:44,110
150,000 គឺគ្រប់គ្រាន់ហើយ។

532
00:27:44,550 --> 00:27:46,110
ប៉ុន្តែ​បើ​វា​ជា​ផ្នែក C វិញ

533
00:27:46,110 --> 00:27:47,170
វាអាចនឹងត្រូវចំណាយកាន់តែច្រើន។

534
00:27:51,130 --> 00:27:52,990
កុំពិភាក្សារឿងនេះជាសាធារណៈ។

535
00:27:55,240 --> 00:27:56,590
គ្រប់គ្នាពិតជាមិនដឹងមែនទេ?

536
00:27:56,590 --> 00:27:57,680
ថ្ងៃនេះជាលោក នី

537
00:27:57,680 --> 00:27:59,310
ថ្ងៃនៃសុភមង្គលទ្វេដង។

538
00:28:00,350 --> 00:28:01,350
គាត់នឹងក្លាយជាឪពុក។

539
00:28:02,790 --> 00:28:03,640
សួស្តីអ្នកទាំងអស់គ្នា។

540
00:28:03,640 --> 00:28:05,040
ខ្ញុំសុំទោសដែលយឺត។

541
00:28:17,230 --> 00:28:18,790
សូមទោស ខ្ញុំមកបន្ទប់ខុស។

542
00:28:18,790 --> 00:28:20,920
Lu Zhenzhen ហេតុអ្វីបានជាអ្នករត់ចេញ?

543
00:28:22,560 --> 00:28:23,450
ខ្ញុំមិនមែនទេ។

544
00:28:25,230 --> 00:28:25,990
នាង នី

545
00:28:26,440 --> 00:28:28,370
ខ្ញុំចាកចេញដោយការគោរពចំពោះអ្នក។

546
00:28:30,590 --> 00:28:31,790
ចេញពីការគោរពចំពោះខ្ញុំ?

547
00:28:33,050 --> 00:28:34,450
វាស្តាប់ទៅគួរឱ្យអស់សំណើចណាស់។

548
00:28:35,160 --> 00:28:36,440
ដូចជាប្រសិនបើខ្ញុំជាម្ចាស់ស្រី។

549
00:28:36,780 --> 00:28:37,860
ម្ចាស់ស្រី?

550
00:28:41,380 --> 00:28:43,840
លោក Yang នាងមកពី Yuhua មែនទេ?

551
00:28:44,050 --> 00:28:45,180
សុំទោសអ្នកទាំងអស់គ្នា។

552
00:28:45,210 --> 00:28:46,240
ប្រពន្ធខ្ញុំស្រវឹង។

553
00:28:46,260 --> 00:28:46,880
ខ្ញុំនឹងយកនាងទៅផ្ទះ។

554
00:28:46,880 --> 00:28:47,680
- ខ្ញុំមិនស្រវឹងទេ។
- តោះទៅ។

555
00:28:47,680 --> 00:28:49,680
- តើខ្ញុំអាចស្រវឹងបានដោយរបៀបណា?
- អ្នកស្រវឹង។ តោះទៅផ្ទះវិញ?

556
00:28:49,680 --> 00:28:50,480
លែងខ្ញុំទៅ!

557
00:28:50,480 --> 00:28:51,520
លែងខ្ញុំទៅ!

558
00:28:51,600 --> 00:28:52,410
អនុញ្ញាតឱ្យទៅ!

559
00:28:54,750 --> 00:28:55,920
តើអ្នកមានបញ្ហាអ្វី?

560
00:28:55,920 --> 00:28:58,180
ឯងខ្លាចហើយមែនទេ នី យូឆេង?

561
00:28:58,310 --> 00:28:59,270
ធ្លាប់ហើយ

562
00:28:59,270 --> 00:29:01,800
Xu Miyu ដែលតែងតែអានអារម្មណ៍របស់អ្នក។
និងធ្វើសកម្មភាពតាម,

563
00:29:01,800 --> 00:29:03,720
ដែលធ្វើសកម្មភាពនៅចំពោះមុខចៅហ្វាយរបស់អ្នក។
និងសហសេវិក

564
00:29:03,720 --> 00:29:05,550
ដូចជាល្អឥតខ្ចោះ

565
00:29:05,550 --> 00:29:06,750
យល់ចិត្តប្រពន្ធ។

566
00:29:07,960 --> 00:29:09,310
ប៉ុន្តែ Xu Miyu នេះនៅចំពោះមុខអ្នក

567
00:29:09,310 --> 00:29:12,040
ធ្វើឱ្យអ្នកមានអារម្មណ៍ដូច
អ្នកមិនអាចគ្រប់គ្រងនាងបានទេមែនទេ?

568
00:29:14,570 --> 00:29:15,470
ខ្ញុំសូមប្រាប់អ្នក។

569
00:29:16,110 --> 00:29:17,410
ចាប់ពីថ្ងៃនេះតទៅ

570
00:29:17,850 --> 00:29:19,000
គ្រប់យ៉ាងដែលខ្ញុំធ្វើ

571
00:29:19,000 --> 00:29:20,160
រាល់ពាក្យដែលខ្ញុំនិយាយ

572
00:29:20,160 --> 00:29:21,400
ខ្ញុំនឹងមិនព្យាយាមផ្គាប់ចិត្តអ្នកទៀតទេ។

573
00:29:21,400 --> 00:29:23,440
ខ្ញុំមិនខ្វល់ថាអ្នកសប្បាយចិត្តឬអត់នោះទេ។

574
00:29:24,730 --> 00:29:25,810
អូនខ្វល់តែ

575
00:29:26,400 --> 00:29:27,310
ប្រសិនបើខ្ញុំសប្បាយចិត្ត។

576
00:29:34,250 --> 00:29:35,290
កញ្ញា លូ។

577
00:29:36,040 --> 00:29:37,000
កូនយ៉ាងម៉េចហើយ?

578
00:29:38,800 --> 00:29:40,730
តើការពិនិត្យមុនពេលសម្រាលមានដំណើរការល្អទេ?

579
00:29:48,430 --> 00:29:49,360
កុំខ្លាចអី។

580
00:29:49,460 --> 00:29:51,460
ខ្ញុំគ្រាន់តែចង់មើលអ្នកឱ្យបានល្អ។

581
00:29:54,240 --> 00:29:55,090
ពិត។

582
00:29:56,900 --> 00:29:57,900
ក្មេង

583
00:29:58,670 --> 00:29:59,510
ស្អាត

584
00:30:00,710 --> 00:30:01,790
ល្បិច,

585
00:30:03,000 --> 00:30:04,400
និងដោយគ្មានគោលការណ៍។

586
00:30:05,420 --> 00:30:07,090
តើនេះនិយាយអ្វីទៀត?

587
00:30:05,460 --> 00:30:06,570
[ពិធីជប់លៀង
សម្រាប់គម្រោង Yufeng Jiangnan]

588
00:30:08,360 --> 00:30:11,620
អ្នកណាទាបជាងគេទៅ
ពួកគេកាន់តែមិនឈប់ឈរ។

589
00:30:12,160 --> 00:30:12,990
នោះជាសិទ្ធិ។

590
00:30:14,070 --> 00:30:16,200
ប៉ុន្តែរសជាតិរបស់អ្នកមិនសូវល្អទេ។

591
00:30:17,190 --> 00:30:18,350
មនុស្សដែលអូនធ្លាប់ដួល

592
00:30:18,350 --> 00:30:20,610
ជា​បុរស​ដែល​មាន​ភាព​ប៉ិនប្រសប់ និង​បម្រើ​ខ្លួន​ឯង។

593
00:30:21,350 --> 00:30:24,660
ប្រសិនបើអ្នកមិនគិតច្រើនទេ។
ជាងគាត់

594
00:30:24,780 --> 00:30:25,680
ខ្ញុំខ្លាច

595
00:30:25,700 --> 00:30:26,880
វា​នឹង​មិន​ល្អ​ទេ

596
00:30:28,070 --> 00:30:29,980
ប្រសិនបើអ្នកនៅជាមួយគាត់។

597
00:30:34,040 --> 00:30:35,430
Nie Yucheng តើខ្ញុំត្រូវទេ?

598
00:30:35,580 --> 00:30:39,950
[ពិធីជប់លៀង
សម្រាប់គម្រោង Yufeng Jiangnan]

599
00:30:36,480 --> 00:30:38,480
តើយើងរៀបការប៉ុន្មានឆ្នាំហើយ?

600
00:30:39,120 --> 00:30:40,400
ដប់ឆ្នាំមែនទេ?

601
00:30:41,730 --> 00:30:43,210
ពេលវេលាហោះហើរ។

602
00:30:44,450 --> 00:30:46,850
ក្នុងមួយប៉ព្រិចភ្នែក។
10 ឆ្នាំបានកន្លងផុតទៅ។

603
00:30:47,360 --> 00:30:48,570
តាមពិតខ្ញុំតែងតែស្គាល់

604
00:30:48,570 --> 00:30:50,460
ថាអ្នកជាមនុស្សអាត្មានិយម។

605
00:30:50,720 --> 00:30:52,230
អ្នកថាអ្នកមានបញ្ហាក្រពះ

606
00:30:52,230 --> 00:30:53,480
ដូច្នេះខ្ញុំស្ម័គ្រចិត្ត

607
00:30:53,510 --> 00:30:55,640
ក្លាយជាស្ត្រីមេផ្ទះ១០ឆ្នាំ

608
00:30:55,880 --> 00:30:57,880
រៀបចំអាហារជូនអ្នក

609
00:30:57,900 --> 00:31:00,370
និងគាំទ្រអ្នកគ្រប់ជំហាននៃផ្លូវ
ដូចដែលអាជីពរបស់អ្នករីកចម្រើន។

610
00:31:00,370 --> 00:31:01,810
តើអ្នកដឹងទេថាហេតុអ្វី?

611
00:31:03,970 --> 00:31:05,030
ព្រោះខ្ញុំស្រលាញ់អ្នក។

612
00:31:05,140 --> 00:31:06,820
ខ្ញុំស្រឡាញ់គ្រួសាររបស់យើង។

613
00:31:07,010 --> 00:31:09,000
Miyu តើ​យើង​មិន​អាច​ធ្វើ​បែប​នេះ​គាត់​ទេ—

614
00:31:09,320 --> 00:31:11,740
រហូតដល់ខ្ញុំបានឃើញផ្ទាល់ភ្នែក
តើអ្នកជាន់ឈ្លីសេចក្តីថ្លៃថ្នូររបស់ខ្ញុំ

615
00:31:11,740 --> 00:31:13,530
ជាមួយស្ត្រីផ្សេងទៀត។

616
00:31:16,630 --> 00:31:17,770
ខ្ញុំមកទីនេះថ្ងៃនេះ

617
00:31:19,110 --> 00:31:20,890
យកមកវិញ

618
00:31:21,320 --> 00:31:22,820
សេចក្តីថ្លៃថ្នូរដែលខ្ញុំបាត់បង់

619
00:31:25,850 --> 00:31:27,020
ដណ្ដើម​យក​ខ្លួន​ឯង

620
00:31:27,300 --> 00:31:29,780
វាមិនមានសូម្បីតែនៅក្នុងភ្នែករបស់អ្នក។

621
00:31:32,490 --> 00:31:33,540
ណយ យ៉េង,

622
00:31:34,810 --> 00:31:36,000
ចូរយើងលែងលះគ្នា។

623
00:31:41,340 --> 00:31:43,770
[ពិធីជប់លៀង
សម្រាប់គម្រោង Yufeng Jiangnan]

624
00:31:57,070 --> 00:31:57,840
Xu Miyu ។

625
00:32:00,080 --> 00:32:00,990
Xu Miyu!

626
00:32:01,990 --> 00:32:03,500
តើអ្នកកំពុងព្យាយាមធ្វើអ្វីពិតប្រាកដ?

627
00:32:03,500 --> 00:32:05,160
បន្ទប់ពេញទៅដោយដៃគូអាជីវកម្មរបស់ខ្ញុំ។

628
00:32:05,160 --> 00:32:07,310
ហេតុអ្វីបានជាអ្នកនិយាយរឿងទាំងនោះ
នៅចំពោះមុខពួកគេ?

629
00:32:07,310 --> 00:32:07,980
ហេតុអ្វី?

630
00:32:08,120 --> 00:32:08,750
អូនគ្មានខ្មាស់ទេ

631
00:32:08,750 --> 00:32:09,660
ប៉ុន្តែខ្ញុំធ្វើ!

632
00:32:09,810 --> 00:32:11,210
តើអ្នកមិនចង់លែងលះទេ?

633
00:32:11,370 --> 00:32:12,890
តើអ្វីផ្តល់សិទ្ធិឱ្យអ្នកលែងលះខ្ញុំ?

634
00:32:12,890 --> 00:32:14,660
អ្វី​ដែល​ធ្វើ​ឱ្យ​អ្នក​គិត​ថា​អ្នក​អាច​លែង​ឱ្យ​ខ្ញុំ​?

635
00:32:14,660 --> 00:32:16,490
តើអ្នកគិតថាអ្នកនឹងមានជីវិតល្អ។
បន្ទាប់ពីលែងលះខ្ញុំ?

636
00:32:16,490 --> 00:32:17,410
អ្នកនឹងមិន!

637
00:32:17,550 --> 00:32:18,890
អ្នកមិនមែនជាប៉ារ៉ាស៊ីតទេ!

638
00:32:18,890 --> 00:32:20,550
គ្រួសារទាំងមូលរបស់អ្នកដូចគ្នា!

639
00:32:27,960 --> 00:32:28,720
Xu Miyu!

640
00:32:30,700 --> 00:32:32,230
ចាំ​មើល​ថា​អាច​ទៅ​បាន​ឆ្ងាយ​ប៉ុណ្ណា​!

641
00:32:33,140 --> 00:32:35,870
បើអ្នកមានសមត្ថភាពខ្លាំង
កុំ​មក​អង្វរ​ខ្ញុំ!

642
00:32:49,360 --> 00:32:51,470
♪ ខ្ញុំដឹងនៅដើមរឿង ♪

643
00:32:52,430 --> 00:32:54,450
♪ ពួកគេទាំងអស់គ្នាមានអារម្មណ៍ដូចគ្នាខ្លះ ♪

644
00:32:56,320 --> 00:32:58,590
♪ មិនដែលគិតថាខ្ញុំនឹង♪

645
00:32:59,640 --> 00:33:01,550
♪ ធ្លាក់ខ្លួនឈឺយ៉ាងនេះ♪

646
00:33:03,370 --> 00:33:05,690
♪ ហេតុអ្វីខ្ញុំត្រូវបាត់បង់ខ្លួនឯង? ♪

647
00:33:06,220 --> 00:33:08,360
♪នៅក្នុងពិភពនិម្មិត♪

648
00:33:09,710 --> 00:33:15,230
♪ សុបិន្តដែលមិនទាន់បញ្ចប់ ឈឺចាប់បំផុត♪

649
00:33:16,650 --> 00:33:18,470
♪ ដូច​ជា​ខែ​ដែល​ទាញ​ចូល​ទៅ​ក្នុង​ភ្លើង ♪

650
00:33:19,050 --> 00:33:22,280
♪ វង្វេងដោយគ្មានគោលដៅ
ឆ្លងកាត់មេឃពេលយប់♪

651
00:33:22,160 --> 00:33:23,940
អ្វី​ដែល​ធ្វើ​ឱ្យ​អ្នក​គិត​ថា​អ្នក​អាច​លែង​ឱ្យ​ខ្ញុំ​?

652
00:33:23,940 --> 00:33:25,530
♪ ទាល់តែបានជួបអ្នក♪

653
00:33:24,210 --> 00:33:26,070
តើអ្នកគិតថាអ្នកនឹងមានជីវិតល្អ។
បន្ទាប់ពីលែងលះខ្ញុំ?

654
00:33:26,070 --> 00:33:26,960
អ្នកនឹងមិន!

655
00:33:26,330 --> 00:33:29,430
♪ ដូចជាភ្លើងដែលឆក់យកជីវិតខ្ញុំ ♪

656
00:33:30,010 --> 00:33:31,800
♪ ខ្ញុំបានគិតពីការលះបង់ដ៏ជ្រាលជ្រៅរបស់ខ្ញុំ
និងភាពស្មោះត្រង់♪

657
00:33:32,430 --> 00:33:34,090
♪ នឹងទទួលបានភាពស្មោះត្រង់ដ៏អស់កល្បរបស់អ្នក♪

658
00:33:33,880 --> 00:33:35,160
អ្នកមិនមែនជាប៉ារ៉ាស៊ីតទេ!

659
00:33:34,530 --> 00:33:35,760
♪ ព្រោះអូនដូចពពក♪

660
00:33:35,180 --> 00:33:36,530
គ្រួសារទាំងមូលរបស់អ្នកដូចគ្នា!

661
00:33:36,250 --> 00:33:37,950
♪ ខ្ញុំក្លាយជាខ្យល់បក់ ♪

662
00:33:38,280 --> 00:33:41,330
♪ ទីបំផុតការសន្យាទាំងអស់ដែលយើងបានធ្វើ♪

663
00:33:41,410 --> 00:33:45,190
[សម្រាប់តែឥទ្ធិពលដ៏អស្ចារ្យប៉ុណ្ណោះ។ កុំត្រាប់តាម]

664
00:33:41,720 --> 00:33:43,190
♪ ប្រែក្លាយទៅជាគ្មានអ្វីក្រៅពីភាពទទេ ♪

665
00:33:44,280 --> 00:33:45,970
♪ ម្តងដើម្បីក្តីសុបិនរបស់អ្នក♪

666
00:33:46,270 --> 00:33:47,660
♪ ខ្ញុំគ្រវីធ្មេញ
ហើយរុញខ្លួនខ្ញុំទៅមុខ♪

667
00:33:48,740 --> 00:33:50,780
♪ ស្នេហាពិតជាឈឺចាប់♪

668
00:33:52,170 --> 00:33:56,520
♪ ខ្ញុំមិនដែលស្មានថាខ្ញុំអាចក្លាហានបានឡើយ ♪

669
00:34:09,469 --> 00:34:11,320
♪ ដូច​ជា​ខែ​ដែល​ទាញ​ចូល​ទៅ​ក្នុង​ភ្លើង ♪

670
00:34:11,770 --> 00:34:15,130
♪ វង្វេងដោយគ្មានគោលដៅ
ឆ្លងកាត់មេឃពេលយប់♪

671
00:34:16,760 --> 00:34:18,380
♪ ទាល់តែបានជួបអ្នក♪

672
00:34:19,150 --> 00:34:22,210
♪ ដូចជាភ្លើងដែលឆក់យកជីវិតខ្ញុំ ♪

673
00:34:22,980 --> 00:34:24,850
♪ ខ្ញុំបានគិតពីការលះបង់ដ៏ជ្រាលជ្រៅរបស់ខ្ញុំ
និងភាពស្មោះត្រង់♪

674
00:34:25,290 --> 00:34:27,020
♪ នឹងទទួលបានភាពស្មោះត្រង់ដ៏អស់កល្បរបស់អ្នក♪

675
00:34:27,460 --> 00:34:28,719
♪ ព្រោះអូនដូចពពក♪

676
00:34:29,070 --> 00:34:30,840
♪ ខ្ញុំក្លាយជាខ្យល់បក់ ♪

677
00:34:30,840 --> 00:34:31,800
Xu Miyu?

678
00:34:31,250 --> 00:34:34,270
♪ ទីបំផុតការសន្យាទាំងអស់ដែលយើងបានធ្វើ♪

679
00:34:34,600 --> 00:34:36,070
♪ ប្រែក្លាយទៅជាគ្មានអ្វីក្រៅពីភាពទទេ ♪

680
00:34:36,880 --> 00:34:37,889
Li Qiaoqi?

681
00:34:37,219 --> 00:34:38,730
♪ ម្តងដើម្បីក្តីសុបិនរបស់អ្នក♪

682
00:34:39,080 --> 00:34:40,730
♪ ខ្ញុំគ្រវីធ្មេញ
ហើយរុញខ្លួនខ្ញុំទៅមុខ♪

683
00:34:39,110 --> 00:34:39,920
លោតលើ។

684
00:34:41,670 --> 00:34:43,719
♪ ស្នេហាពិតជាឈឺចាប់♪

685
00:34:44,830 --> 00:34:49,500
♪ ខ្ញុំមិនដែលស្មានថាខ្ញុំអាចក្លាហានបានឡើយ ♪

686
00:34:52,989 --> 00:34:55,710
♪ មានតែពេលដែលអ្នកឈឺចាប់ដោយសារស្នេហា
តើអ្នកដឹងទេថាអ្នកធ្លាប់ឆ្កួតប៉ុណ្ណា♪

687
00:34:56,210 --> 00:34:59,130
♪ សុបិន្តដ៏ស្រស់ស្អាត
ក្លាយជាសុបិន្តអាក្រក់ភ្លាមៗ♪

688
00:34:56,739 --> 00:34:57,660
ឈីវឈី,

689
00:34:57,880 --> 00:34:59,620
ផ្លូវគឺសើមនិងរអិល។ ជិះយឺត ៗ ។

690
00:34:59,620 --> 00:35:01,370
វាមិនអីទេ។ សង្កត់​ឲ្យ​ជាប់!

691
00:35:00,380 --> 00:35:05,270
♪ អ្នកគឺជាពន្លឺអ៊ីយូតា
ខ្ញុំមិនអាចចាប់♪

692
00:35:04,190 --> 00:35:06,150
យើងកំពុងហោះ!

693
00:35:06,180 --> 00:35:08,400
Li Qiaoqi បន្ថយល្បឿន!

694
00:35:06,240 --> 00:35:08,160
♪ ខ្ញុំស្រលាញ់អ្នកដោយមិនដឹងខ្លួន♪

695
00:35:08,430 --> 00:35:09,320
ខ្ញុំខ្លាច!

696
00:35:09,320 --> 00:35:12,710
Li Qiaoqi ចេញដំណើរជាមួយ Xu Miyu!

697
00:35:09,540 --> 00:35:11,910
♪ ហើយបញ្ចប់ដោយរបួស♪

698
00:35:13,040 --> 00:35:14,270
♪ តែខ្ញុំនៅតែជឿជាក់♪

699
00:35:15,280 --> 00:35:17,590
♪ មេឃក្រោយភ្លៀង♪

700
00:35:19,430 --> 00:35:21,430
♪ ខ្ញុំបានគិតពីការលះបង់ដ៏ជ្រាលជ្រៅរបស់ខ្ញុំ
និងភាពស្មោះត្រង់♪

701
00:35:21,800 --> 00:35:23,430
♪ នឹងទទួលបានភាពស្មោះត្រង់ដ៏អស់កល្បរបស់អ្នក♪

702
00:35:23,970 --> 00:35:25,230
♪ ព្រោះអូនដូចពពក♪

703
00:35:25,580 --> 00:35:27,340
♪ ខ្ញុំក្លាយជាខ្យល់បក់ ♪

704
00:35:27,750 --> 00:35:30,780
♪ ទីបំផុតការសន្យាទាំងអស់ដែលយើងបានធ្វើ♪

705
00:35:31,110 --> 00:35:32,580
♪ ប្រែក្លាយទៅជាគ្មានអ្វីក្រៅពីភាពទទេ ♪

706
00:35:33,720 --> 00:35:35,230
♪ ម្តងដើម្បីក្តីសុបិនរបស់អ្នក♪

707
00:35:35,590 --> 00:35:37,230
♪ ខ្ញុំគ្រវីធ្មេញ
ហើយរុញខ្លួនខ្ញុំទៅមុខ♪

708
00:35:38,180 --> 00:35:40,230
♪ ស្នេហាពិតជាឈឺចាប់♪

709
00:35:41,340 --> 00:35:46,010
♪ ខ្ញុំមិនដែលស្មានថាខ្ញុំអាចក្លាហានបានឡើយ ♪

710
00:35:49,160 --> 00:35:54,390
♪ នៅទីបំផុត អ្វីៗក៏គ្មានន័យ ♪

711
00:35:50,600 --> 00:35:54,330
[សេវាកម្មអាហារពេលព្រឹក: 06:30]

712
00:35:53,790 --> 00:35:55,390
តើមានអ្វីខុស? មានអារម្មណ៍ធ្លាក់ចុះ?

713
00:36:00,780 --> 00:36:02,510
តើអ្នកត្រលប់មកប្រទេសចិនវិញនៅពេលណា?

714
00:36:02,910 --> 00:36:04,310
ខ្ញុំ​បាន​ត្រឡប់​មក​វិញ​មួយ​ឆ្នាំ​ហើយ។

715
00:36:04,400 --> 00:36:06,800
ខ្ញុំបានធ្វើការជាចុងភៅ
នៅ​សណ្ឋាគារ Purong។

716
00:36:09,340 --> 00:36:11,070
ដូច្នេះក្តីសុបិន្តរបស់អ្នកពិតជាបានក្លាយជាការពិត?

717
00:36:11,510 --> 00:36:13,640
ធ្វើការជាចុងភៅនៅសណ្ឋាគារលំដាប់ផ្កាយប្រាំ?

718
00:36:13,850 --> 00:36:14,550
នោះពិតជាអស្ចារ្យណាស់។

719
00:36:14,550 --> 00:36:15,880
ខ្ញុំគ្រាន់តែជាមេចុងភៅប៉ុណ្ណោះ។

720
00:36:17,190 --> 00:36:19,670
តែបើអ្នកស្នាក់នៅសណ្ឋាគារយើងឆ្នាំនេះ

721
00:36:19,690 --> 00:36:22,090
អ្នកប្រហែលជាបានភ្លក់រសជាតិម្ហូបរបស់ខ្ញុំហើយ។

722
00:36:25,630 --> 00:36:26,940
ស្តាប់ខ្ញុំដើរលេង។

723
00:36:27,360 --> 00:36:28,760
អ្នកមានផ្ទះផ្ទាល់ខ្លួននៅទីនេះ។

724
00:36:28,760 --> 00:36:30,490
ហេតុអ្វីបានជាអ្នកស្នាក់នៅសណ្ឋាគាររបស់យើង?

725
00:36:35,760 --> 00:36:36,760
តើអ្នករស់នៅទីណា?

726
00:36:36,810 --> 00:36:38,070
ខ្ញុំបានជួលផ្ទះល្វែងមួយ។

727
00:36:38,070 --> 00:36:39,470
វាមិនឆ្ងាយពី Purong ទេ។

728
00:36:41,260 --> 00:36:43,120
ការជួលត្រូវតែថ្លៃនៅទីនោះ។

729
00:36:43,360 --> 00:36:45,230
មិនពិតទេ។ ខ្ញុំរស់នៅម្នាក់ឯង

730
00:36:45,260 --> 00:36:46,730
ចំណាយលុយខ្លួនឯងតាមចិត្ត។

731
00:36:46,730 --> 00:36:47,930
អ្នកនៅលីវមែនទេ?

732
00:36:48,630 --> 00:36:49,890
ខ្ញុំចូលចិត្តនៅលីវ។

733
00:36:50,070 --> 00:36:52,400
មនុស្សម្នាក់ទៀតគ្រាន់តែធ្វើឱ្យស្មុគស្មាញ។

734
00:36:54,630 --> 00:36:55,510
ខ្ញុំមិនគួរ

735
00:36:55,510 --> 00:36:56,960
ដាក់គំនិតពុលទាំងនេះនៅក្នុងក្បាលរបស់អ្នក។

736
00:36:56,960 --> 00:36:58,500
អ្នក​មាន​គោល​ដៅ​គ្រួសារ​ណាស់។

737
00:36:58,500 --> 00:37:01,160
អ្នកគួរតែទៅផ្ទះ
និងថែរក្សាប្តីរបស់អ្នក។

738
00:37:11,190 --> 00:37:11,920
Qiaoqi ។

739
00:37:12,960 --> 00:37:14,150
សូមអរគុណសម្រាប់ថ្ងៃនេះ។

740
00:37:14,560 --> 00:37:17,150
វាពិតជាអស្ចារ្យណាស់ដែលបានជួបអ្នកម្តងទៀត។

741
00:37:17,340 --> 00:37:19,080
ហេតុអ្វី​បាន​ជា​អ្នក​មាន​លក្ខណៈ​ជា​ផ្លូវការ​ដូច្នេះ?

742
00:37:19,080 --> 00:37:20,860
អ្នក​មិន​ដែល​ត្រូវ​បាន​បម្រុង​ទុក​នេះ​ពី​មុន​មក​។

743
00:37:20,860 --> 00:37:23,260
អាពាហ៍ពិពាហ៍មិនបានរំខានខួរក្បាលរបស់អ្នកទេ
បានធ្វើ?

744
00:37:24,850 --> 00:37:25,690
ប្រហែល។

745
00:37:27,220 --> 00:37:28,670
បន្ទាប់មកអ្នកបានជួបមនុស្សត្រឹមត្រូវ។

746
00:37:28,670 --> 00:37:30,650
ខ្ញុំនឹងនាំអ្នកចេញបន្ថែមទៀតនៅពេលដែលខ្ញុំមានពេល,

747
00:37:30,650 --> 00:37:31,890
ដូចកាលយើងនៅក្មេងដែរ។

748
00:37:31,890 --> 00:37:32,740
វាជាកិច្ចព្រមព្រៀងមួយ។

749
00:37:32,740 --> 00:37:34,450
ខ្ញុំនឹងរង់ចាំការអញ្ជើញរបស់អ្នក។

750
00:37:34,450 --> 00:37:36,110
តោះទៅ។ ខ្ញុំនឹងអោយអ្នកជិះ។

751
00:38:00,770 --> 00:38:05,610
[កិច្ចព្រមព្រៀងលែងលះ]

752
00:38:06,860 --> 00:38:09,150
[ស្នាមម្រាមដៃប្តី]
[ប្រពន្ធស្នាមម្រាមដៃ]

753
00:38:14,850 --> 00:38:15,600
ឈប់។

754
00:38:28,630 --> 00:38:29,740
ចុះហត្ថលេខានេះមុនពេលអ្នកចាកចេញ។

755
00:38:29,740 --> 00:38:30,600
អ្នកពិតជានឹងធ្វើបែបនេះមែនទេ?

756
00:38:30,600 --> 00:38:31,730
ខ្ញុំបានចុះហត្ថលេខារួចហើយ។

757
00:38:31,730 --> 00:38:32,560
នៅសល់ទាំងអស់គឺជាហត្ថលេខារបស់អ្នក។

