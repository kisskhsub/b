ចំពោះអ្វីដែលខ្ញុំត្រូវនិយាយបន្ទាប់។

584
00:29:33,830 --> 00:29:35,830
អនាគត់មិនថា

585
00:29:35,830 --> 00:29:38,350
ទីតាំងណាដែលអ្នកបង្វិលទៅសណ្ឋាគារ

586
00:29:38,350 --> 00:29:39,880
អ្នកត្រូវតែចងចាំយ៉ាងមុតមាំ៖

587
00:29:40,030 --> 00:29:41,400
ធ្វើអោយភ្ញៀវមានអារម្មណ៍នៅផ្ទះ

588
00:29:41,400 --> 00:29:44,110
គឺជាគោលការណ៍នៃសេវាកម្មរបស់សណ្ឋាគារ Purong របស់យើង។

589
00:29:44,310 --> 00:29:47,380
វាអាចស្តាប់ទៅដូចជា cliché បន្តិច,

590
00:29:47,590 --> 00:29:49,030
តែខ្ញុំជឿ

591
00:29:49,030 --> 00:29:51,950
វាជាមូលដ្ឋានគ្រឹះនៃសេវាកម្មសណ្ឋាគាររបស់យើង។

592
00:29:52,110 --> 00:29:54,160
ពេលភ្ញៀវដើរចូលសណ្ឋាគារ

593
00:29:54,270 --> 00:29:56,670
គ្រប់ផ្នែកនៃសណ្ឋាគាររបស់យើង

594
00:29:56,690 --> 00:29:58,780
ចាប់ផ្តើមធ្វើការឱ្យពួកគេ។

595
00:29:58,810 --> 00:30:01,000
យើងត្រូវយល់ច្បាស់

596
00:30:01,020 --> 00:30:03,020
រាល់តម្រូវការរបស់ភ្ញៀវ

597
00:30:03,050 --> 00:30:05,900
និងបំពេញគ្រប់អារម្មណ៍របស់ពួកគេ

598
00:30:06,350 --> 00:30:10,160
ការផ្តល់សេវា
យកចិត្តទុកដាក់ជាងនៅផ្ទះ។

599
00:30:10,180 --> 00:30:12,260
សណ្ឋាគារ ពោធិ៍រ៉ុង ត្រូវបានបង្កើតឡើង

600
00:30:12,350 --> 00:30:13,810
ជិតកន្លះសតវត្សមុន

601
00:30:13,880 --> 00:30:16,640
ហើយនេះជារបៀបដែលយើងរក្សាភ្ញៀវរបស់យើង។

602
00:30:17,460 --> 00:30:19,400
នៅក្នុងការងារនាពេលអនាគតរបស់អ្នក

603
00:30:19,430 --> 00:30:20,630
សង្ឃឹម

604
00:30:20,680 --> 00:30:23,110
នៅគ្រប់សេវាកម្ម

605
00:30:23,130 --> 00:30:24,370
អ្នកអាចយល់

606
00:30:24,400 --> 00:30:26,800
អត្ថន័យនៃការងារនៅក្នុងសណ្ឋាគារ។

607
00:30:26,820 --> 00:30:28,340
នេះក៏ជាតម្លៃ

608
00:30:28,370 --> 00:30:30,170
ដែល Purong ផ្តល់ឱ្យអ្នក។

609
00:31:28,140 --> 00:31:31,490
[អ្នកគ្រប់គ្រងសណ្ឋាគារ] [ព័ត៌មានលម្អិត]

610
00:31:31,590 --> 00:31:32,380
